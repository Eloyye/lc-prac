{
  "name": "codetype",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.15",
    "dompurify": "^3.2.7",
    "marked": "^14.0.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vscode-languageserver-protocol": "^3.18.0",
    "vscode-ws-jsonrpc": "^3.5.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "pyright": "^1.1.410",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.3"
}
